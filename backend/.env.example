# ===== SmartHome Backend Environment Variables =====

# Server
PORT=4000
FRONTEND_URL=http://localhost:3000

# Firebase Admin
# Download your service account key from:
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Save it as `serviceAccountKey.json` in the backend folder
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# MQTT Broker (for ESP32 communication)
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ===== Chat Bots & Social Media Integrations =====
# The AI needs to know who you are in Firestore to control your devices.
# Copy your User ID from the Firebase Authentication tab.
FIREBASE_OWNER_USER_ID=your_firebase_uid_here

# Telegram Bot Setup
# 1. Talk to @BotFather on Telegram, use /newbot, and paste the Token below.
TELEGRAM_BOT_TOKEN=
# Optional: Set your numeric Telegram Chat ID to prevent strangers from using the bot.
TELEGRAM_OWNER_CHAT_ID=

# Discord Bot Setup
# 1. Go to Discord Developer Portal -> New Application -> Bot -> Reset Token
# 2. Enable "Message Content Intent" in the Bot tab!
DISCORD_BOT_TOKEN=
